{
  "ConnectionStrings": {
    "DefaultConnection": "DataSource=Data\\app.db;Cache=Shared"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AI": {
    "DefaultProvider": "azure-openai",
    "Providers": [
      {
        "Name": "Azure OpenAI",
        "Code": "azure-openai",
        "AiType": "AzureOpenAI",
        "ApiKey": "",
        "ApiEndpoint": "https://my-openapi.openai.azure.com",
        "ApiServices": [
          {
            "Name": "chat-completions",
            "ModelId": "gpt-4o"
          },
          {
            "Name": "embeddings",
            "ModelId": "text-embedding-3-small"
          }
        ]
      },
      {
        "Name": "深度求索",
        "Code": "deepseek",
        "AiType": "OpenAI_Compatible",
        "ApiKey": "YOUR-KEY",
        "ApiEndpoint": "https://api.deepseek.com",
        "ApiServices": [
          {
            "Name": "chat-completions",
            "ModelId": "deepseek-chat"
          }
        ]
      }
    ]
  },
  "Prompts": {
    "RootDirectory": "FitTrack.Copilot/SemanticKernel/Plugins/SystemPrompt",
    "ResourcePrefix": "FitTrack.Copilot.SemanticKernel.Plugins.SystemPrompt"
  }
}

@page "/chat"
@using System.Text
@using FitTrack.Copilot.Abstractions.Models
@using FitTrack.Copilot.Service
@using Microsoft.AspNetCore.Components.Forms
@inject IFoodAiService FoodAi
@inject IDialogService Dialog
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mx-auto py-6 px-4">
  <MudPaper Class="p-4 rounded-2xl">
    <!-- Header -->
    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
      <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
        <MudAvatar Icon="@Icons.Material.Filled.Restaurant" Size="Size.Medium" Color="Color.Primary"/>
        <MudText Typo="Typo.h6">Calorie Chat</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Chat-style Food Recognition</MudText>
      </MudStack>

      <MudStack Row Spacing="1">
        <MudIconButton Icon="@Icons.Material.Filled.History" Title="Sample" OnClick="InsertSample"/>
        <MudIconButton Icon="@Icons.Material.Filled.DeleteSweep" Title="Clear chat" Color="Color.Error"
                       OnClick="ClearChat"/>
      </MudStack>
    </MudStack>

    <!-- Message list -->
    <MudDivider Class="mb-3"/>
    <div class="chat-scroll">
      @foreach (var m in Messages)
      {
        <div class="chat-row @(m.Role == Role.User ? "me" : "bot")">
          <MudPaper Class="chat-bubble">
            <MudStack Spacing="1">
              <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                <MudAvatar Icon="@(m.Role == Role.User ? Icons.Material.Filled.Person : Icons.Material.Filled.SmartToy)"
                           Color="@(m.Role == Role.User ? Color.Primary : Color.Secondary)" Size="Size.Small"/>
                <MudText
                  Typo="Typo.caption">@((m.Role == Role.User ? "You" : "FitTrack AI")) · @m.Time.ToLocalTime().ToString("HH:mm")</MudText>
              </MudStack>

              @if (!string.IsNullOrWhiteSpace(m.Text))
              {
                <MudText Typo="Typo.body1">@m.Text</MudText>
              }

              @if (!string.IsNullOrEmpty(m.ImageDataUrl))
              {
                <MudImage Src="@m.ImageDataUrl" Alt="uploaded" Elevation="0" Class="rounded-xl max-w-img"/>
              }

              @if (m.Status == MessageStatus.Loading)
              {
                <MudSkeleton SkeletonType="SkeletonType.Text" Height="20px"/>
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="70%" Height="20px"/>
              }

              @if (m.Nutrition is not null)
              {
                <NutritionCard Result="m.Nutrition"/>
              }

              @if (m.Error is not null)
              {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@m.Error</MudAlert>
              }
            </MudStack>
          </MudPaper>
        </div>
      }
      <div id="chat-bottom"/>
    </div>

    <!-- Composer -->
    <MudDivider Class="my-3" />
    <div class="chat-composer">
      @if (PreviewImage is not null)
      {
        <div class="image-preview">
          <MudImage Src="@PreviewImage" Alt="preview" Class="preview-thumb" />
          <MudIconButton Icon="@Icons.Material.Filled.Close"
                         Color="Color.Error"
                         Class="preview-close"
                         Size="Size.Small"
                         OnClick="()=>PreviewImage=null" />
          <MudText Typo="Typo.caption" Color="Color.Secondary" Class="preview-hint">
            Image selected (not yet sent)
          </MudText>
        </div>
      }

      <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
        <MudFileUpload T="IBrowserFile" FilesChanged="UploadFiles">
          <ActivatorContent>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.CloudUpload">
            </MudButton>
          </ActivatorContent>
        </MudFileUpload>

        <MudTextField @bind-Value="InputText"
                      Lines="1"
                      Placeholder="Describe your food (or send an image)…"
                      Class="flex-1"
                      Adornment="Adornment.Start"
                      Immediate="true"
                      OnKeyDown="OnKeyDown" />

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@IsSending"
                   OnClick="Send">Send</MudButton>
      </MudStack>
    </div>
  </MudPaper>
</MudContainer>


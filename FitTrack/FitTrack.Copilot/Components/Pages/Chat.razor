@page "/chat"
@using FitTrack.Copilot.Abstractions.Models
@using FitTrack.Copilot.Service
@using Microsoft.AspNetCore.Components.Forms
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="chat-root py-6">
  <MudPaper Class="chat-shell">
    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="chat-header">
      <div>
        <MudText Typo="Typo.h5">FitTrack Copilot</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
          Chat with the fitness agent, or send a meal image to the calorie agent.
        </MudText>
      </div>

      <MudStack Row Spacing="1">
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.AutoAwesome" OnClick="InsertFitnessSample">
          Fitness Sample
        </MudButton>
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Restaurant" OnClick="InsertMealSample">
          Meal Sample
        </MudButton>
        <MudIconButton Icon="@Icons.Material.Filled.DeleteSweep" Color="Color.Error" OnClick="ClearChat"/>
      </MudStack>
    </MudStack>

    <MudPaper Class="agent-banner" Elevation="0">
      <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
        <MudChip T="string" Color="@(HasPendingImage ? Color.Warning : Color.Primary)" Variant="Variant.Filled">
          @(HasPendingImage ? "Image Calorie Agent" : "Fitness Agent")
        </MudChip>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
          @(HasPendingImage
              ? "An uploaded image will route this turn to the image calorie agent."
              : "Text-only prompts go to the fitness agent.")
        </MudText>
      </MudStack>
    </MudPaper>

    <div class="chat-scroll">
      @foreach (var m in Messages)
      {
        <div class="chat-row @(m.Role == Role.User ? "me" : "bot")">
          <MudPaper Class="chat-bubble" Elevation="0">
            <MudStack Spacing="1">
              <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                <MudAvatar Icon="@(m.Role == Role.User ? Icons.Material.Filled.Person : Icons.Material.Filled.SmartToy)"
                           Color="@(m.Role == Role.User ? Color.Primary : Color.Secondary)" Size="Size.Small"/>
                <MudText Typo="Typo.caption">
                  @(m.Role == Role.User ? "You" : m.AgentName ?? "Copilot") · @m.Time.ToLocalTime().ToString("HH:mm")
                </MudText>
              </MudStack>

              @if (!string.IsNullOrWhiteSpace(m.Text))
              {
                <MudText Typo="Typo.body1" Class="chat-text">@m.Text</MudText>
              }

              @if (!string.IsNullOrWhiteSpace(m.ImageDataUrl))
              {
                <MudImage Src="@m.ImageDataUrl" Alt="uploaded meal image" Class="chat-img"/>
              }

              @if (m.Status == MessageStatus.Loading)
              {
                <MudSkeleton SkeletonType="SkeletonType.Text" Height="20px"/>
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="68%" Height="20px"/>
              }

              @if (m.Nutrition is not null)
              {
                <NutritionCard Result="m.Nutrition"/>
              }

              @if (!string.IsNullOrWhiteSpace(m.Error))
              {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@m.Error</MudAlert>
              }
            </MudStack>
          </MudPaper>
        </div>
      }
    </div>

    <div class="chat-composer">
      @if (PreviewImage is not null)
      {
        <MudPaper Class="image-preview-card" Elevation="0">
          <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
            <MudImage Src="@PreviewImage" Alt="preview" Class="preview-thumb"/>
            <div class="flex-1">
              <MudText Typo="Typo.subtitle2">Image ready</MudText>
              <MudText Typo="Typo.caption" Color="Color.Secondary">
                This message will use the image calorie agent.
              </MudText>
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" OnClick="ClearPendingImage"/>
          </MudStack>
        </MudPaper>
      }

      <MudStack Row Spacing="2" AlignItems="AlignItems.End">
        <MudFileUpload T="IBrowserFile" FilesChanged="UploadFiles" Accept="image/*">
          <ActivatorContent>
            <MudButton Variant="Variant.Filled"
                       Color="@(HasPendingImage ? Color.Warning : Color.Primary)"
                       StartIcon="@Icons.Material.Filled.AddPhotoAlternate">
              Photo
            </MudButton>
          </ActivatorContent>
        </MudFileUpload>

        <MudTextField @bind-Value="InputText"
                      Placeholder="Ask about workouts, nutrition, BMI, or add context for a meal image..."
                      Lines="2"
                      AutoGrow="true"
                      MaxLines="5"
                      Class="flex-1"
                      Immediate="true"
                      OnKeyDown="OnKeyDown" />

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@IsSending"
                   OnClick="Send">
          Send
        </MudButton>
      </MudStack>
    </div>
  </MudPaper>
</MudContainer>
